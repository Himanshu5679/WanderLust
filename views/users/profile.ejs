<% layout("/layouts/boilerplate.ejs") %>

<div class="row mt-4 mb-4">
  <div class="col-md-6 offset-md-3">
    <div class="card p-4" style="border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.1);">
      <div class="text-center mb-3">
        <i class="fa-solid fa-circle-user" style="font-size: 5rem; color: #717171;"></i>
      </div>
      <h4 class="text-center mb-3">@<%= user.username %></h4>
      <hr>
      <p><b>Email:</b> <%= user.email %></p>
      <p><b>Username:</b> <%= user.username %></p>

      <div class="d-grid gap-2 mt-3">
        <a href="/settings" class="btn btn-outline-dark">Edit Profile</a>
        <a href="/listings/new" class="btn btn-dark">Create a Listing</a>
      </div>
    </div>
  </div>
</div>